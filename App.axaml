<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ComputerCompanion.App"
             xmlns:local="using:ComputerCompanion"
             xmlns:converters="using:ComputerCompanion.Converters"
             RequestedThemeVariant="Default">

    <Application.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#76B900"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1a1a1a"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#2d2d2d"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#aaaaaa"/>
        
        <!-- 中文字体配置 - 确保在所有平台上正确显示中文 -->
        <FontFamily x:Key="ChineseFontFamily">Microsoft YaHei UI, Microsoft YaHei, SimHei, Noto Sans CJK SC, Source Han Sans CN, sans-serif</FontFamily>
        <FontFamily x:Key="DefaultFontFamily">Segoe UI, Microsoft YaHei UI, Microsoft YaHei, Noto Sans CJK SC, Source Han Sans CN, sans-serif</FontFamily>
    </Application.Resources>

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
        <!-- 全局字体样式 -->
        <StyleInclude Source="avares://ComputerCompanion/Styles/GlobalStyles.axaml"/>
        <StyleInclude Source="avares://ComputerCompanion/Styles/SettingsStyles.axaml"/>
    </Application.Styles>
</Application>