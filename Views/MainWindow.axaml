<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="using:ComputerCompanion.ViewModels"
        mc:Ignorable="d" d:DesignWidth="320" d:DesignHeight="280"
        x:Class="ComputerCompanion.Views.MainWindow"
        Title="Computer Companion"
        Background="Transparent"
        Topmost="True"
        Width="320"
        Height="280"
        CanResize="False">
    <Window.Styles>
        <Style>
            <Setter Property="TextBlock.FontFamily" Value="Segoe UI, sans-serif"/>
            <Setter Property="TextBlock.FontSize" Value="12"/>
            <Setter Property="TextBlock.Foreground" Value="White"/>
            <Setter Property="TextBlock.Margin" Value="0 2"/>
        </Style>
    </Window.Styles>

    <Border CornerRadius="12" Background="#1a1a2eea" Padding="16">
        <StackPanel Spacing="8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="⚡" FontSize="20" Margin="0 0 8 0"/>
                <TextBlock Text="Computer Companion" FontSize="14" FontWeight="Bold"/>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <StackPanel Spacing="4">
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding CpuInfo}" Foreground="#4ecdc4"/>
                
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding GpuInfo}" Foreground="#a29bfe" 
                           IsVisible="{Binding ShowGpu}"/>
                
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding MemoryInfo}" Foreground="#fd79a8"/>
                
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding NetworkInfo}" Foreground="#ffeaa7"/>
                
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding DiskInfo}" Foreground="#dfe6e9"/>
                
                <TextBlock x:DataType="viewModels:MainWindowViewModel" Text="{Binding BatteryInfo}" Foreground="#00b894"
                           IsVisible="{Binding ShowBattery}"/>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16">
                <TextBlock Text="F1: Toggle Click" FontSize="10" Foreground="#666"/>
                <TextBlock Text="F2: Game Mode" FontSize="10" Foreground="#666"/>
                <TextBlock Text="Esc: Close" FontSize="10" Foreground="#666"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
