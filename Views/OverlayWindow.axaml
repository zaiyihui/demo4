<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ComputerCompanion.ViewModels"
        mc:Ignorable="d" d:DesignWidth="260" d:DesignHeight="180"
        x:Class="ComputerCompanion.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        Title="电脑伴侣悬浮窗"
        Width="260"
        Height="180"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHintsHint="NoChrome">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, sans-serif"/>
        </Style>
    </Window.Styles>

    <!-- 主容器 -->
    <Grid>
        <!-- 拖拽热区 -->
        <Border 
            HorizontalAlignment="Left" 
            VerticalAlignment="Top" 
            Width="40" 
            Height="20"
            Margin="10,8,0,0"
            Background="#33223322" 
            CornerRadius="3"
            Cursor="SizeAll"
            PointerPressed="OnDragHandlePressed"
            PointerMoved="OnDragHandleMoved"
            PointerReleased="OnDragHandleReleased"
            ToolTip.Tip="拖拽移动">
            <TextBlock 
                Text="≡" 
                FontSize="16" 
                Foreground="#555" 
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="0,-2,0,0"/>
        </Border>
        
        <!-- 内容区域 -->
        <Border 
            Background="#1a1a2e" 
            CornerRadius="12" 
            Padding="16,14"
            Margin="8"
            Opacity="0.9"
            BorderBrush="#333"
            BorderThickness="1"
            BoxShadow="0 6 24 0 #40000000">
            
            <StackPanel Spacing="8">
                <!-- FPS 行 -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock 
                        Grid.Column="0" 
                        Text="FPS" 
                        FontSize="11" 
                        Foreground="#666" 
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1" 
                        x:DataType="vm:OverlayViewModel"
                        Text="{Binding FpsText}" 
                        FontSize="18" 
                        FontWeight="Bold" 
                        Foreground="#76B900"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>
                
                <!-- 分隔线 -->
                <Border Height="1" Background="#333" Margin="0,4"/>
                
                <!-- GPU 行 -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock 
                        Grid.Column="0" 
                        Text="GPU" 
                        FontSize="11" 
                        Foreground="#666" 
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1" 
                        x:DataType="vm:OverlayViewModel"
                        Text="{Binding GpuText}" 
                        FontSize="12" 
                        Foreground="#76B900"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>
                
                <!-- CPU 行 -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock 
                        Grid.Column="0" 
                        Text="CPU" 
                        FontSize="11" 
                        Foreground="#666" 
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1" 
                        x:DataType="vm:OverlayViewModel"
                        Text="{Binding CpuText}" 
                        FontSize="12" 
                        Foreground="#76B900"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>
                
                <!-- 内存行 -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock 
                        Grid.Column="0" 
                        Text="MEM" 
                        FontSize="11" 
                        Foreground="#666" 
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1" 
                        x:DataType="vm:OverlayViewModel"
                        Text="{Binding MemoryText}" 
                        FontSize="12" 
                        Foreground="#76B900"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>
                
                <!-- 延迟行 -->
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock 
                        Grid.Column="0" 
                        Text="LAT" 
                        FontSize="11" 
                        Foreground="#666" 
                        FontWeight="SemiBold"
                        VerticalAlignment="Center"/>
                    <TextBlock 
                        Grid.Column="1" 
                        x:DataType="vm:OverlayViewModel"
                        Text="{Binding LatencyText}" 
                        FontSize="12" 
                        Foreground="#76B900"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>