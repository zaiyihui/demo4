<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ComputerCompanion.ViewModels"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="200"
        x:Class="ComputerCompanion.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        Title="Computer Companion Overlay"
        Width="300"
        Height="200"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid>
        <!-- 悬浮窗内容 -->
        <Border 
            Background="Transparent"
            Padding="16,12">
            <StackPanel Spacing="6">
                <!-- FPS -->
                <TextBlock 
                    x:Name="FpsText"
                    Text="{Binding FpsText}"
                    FontSize="16"
                    FontWeight="Bold"
                    Foreground="{Binding OverlayTextColor, Mode=OneTime}"/>
                
                <!-- GPU -->
                <TextBlock 
                    x:Name="GpuText"
                    Text="{Binding GpuText}"
                    FontSize="14"
                    Foreground="{Binding OverlayTextColor, Mode=OneTime}"/>
                
                <!-- CPU -->
                <TextBlock 
                    x:Name="CpuText"
                    Text="{Binding CpuText}"
                    FontSize="14"
                    Foreground="{Binding OverlayTextColor, Mode=OneTime}"/>
                
                <!-- Memory -->
                <TextBlock 
                    x:Name="MemoryText"
                    Text="{Binding MemoryText}"
                    FontSize="14"
                    Foreground="{Binding OverlayTextColor, Mode=OneTime}"/>
                
                <!-- Latency -->
                <TextBlock 
                    x:Name="LatencyText"
                    Text="{Binding LatencyText}"
                    FontSize="14"
                    Foreground="{Binding OverlayTextColor, Mode=OneTime}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
