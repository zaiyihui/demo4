<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ComputerCompanion.ViewModels"
        mc:Ignorable="d" d:DesignWidth="180" d:DesignHeight="140"
        x:Class="ComputerCompanion.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        Title="悬浮窗"
        Width="180"
        Height="140"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ExtendClientAreaToDecorationsHint="True"
        SystemDecorations="None">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, sans-serif"/>
            <Setter Property="Foreground" Value="#76B900"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.ColumnSpan="2" Grid.Row="0" Margin="4">
            <Border 
                HorizontalAlignment="Left" 
                VerticalAlignment="Top" 
                Width="32" 
                Height="20"
                Background="#20000000" 
                CornerRadius="3"
                Cursor="SizeAll"
                PointerPressed="OnDragHandlePressed"
                PointerMoved="OnDragHandleMoved"
                PointerReleased="OnDragHandleReleased"
                ToolTip.Tip="拖拽移动">
                <TextBlock 
                    Text="≡" 
                    FontSize="14" 
                    Foreground="#666" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <TextBlock Grid.Column="0" Grid.Row="1" Text="FPS" FontSize="10" Foreground="#888" Margin="8,4,4,2"/>
        <TextBlock Grid.Column="1" Grid.Row="1" x:DataType="vm:OverlayViewModel" Text="{Binding FpsText}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,4,8,2"/>

        <TextBlock Grid.Column="0" Grid.Row="2" Text="GPU" FontSize="10" Foreground="#888" Margin="8,2,4,2"/>
        <TextBlock Grid.Column="1" Grid.Row="2" x:DataType="vm:OverlayViewModel" Text="{Binding GpuText}" FontSize="14" HorizontalAlignment="Right" Margin="0,2,8,2"/>

        <TextBlock Grid.Column="0" Grid.Row="3" Text="CPU" FontSize="10" Foreground="#888" Margin="8,2,4,2"/>
        <TextBlock Grid.Column="1" Grid.Row="3" x:DataType="vm:OverlayViewModel" Text="{Binding CpuText}" FontSize="14" HorizontalAlignment="Right" Margin="0,2,8,2"/>

        <TextBlock Grid.Column="0" Grid.Row="4" Text="MEM" FontSize="10" Foreground="#888" Margin="8,2,4,4"/>
        <TextBlock Grid.Column="1" Grid.Row="4" x:DataType="vm:OverlayViewModel" Text="{Binding MemoryText}" FontSize="14" HorizontalAlignment="Right" Margin="0,2,8,4"/>
    </Grid>
</Window>