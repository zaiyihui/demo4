<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ComputerCompanion.ViewModels"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="500"
        x:Class="ComputerCompanion.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="设置"
        Width="400"
        Height="550"
        CanResize="False">

    <Grid Margin="16">
        <StackPanel Spacing="12">
            <!-- 标题 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 0 0 8">
                <TextBlock Text="设置" FontSize="18" FontWeight="Bold" Foreground="White"/>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <!-- 外观设置 -->
            <StackPanel Spacing="8">
                <TextBlock Text="外观" FontSize="14" FontWeight="Bold" Foreground="#4ecdc4"/>
                
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="文字颜色" Width="100" Foreground="#aaa"/>
                        <TextBox Text="{Binding TextColor}" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="背景颜色" Width="100" Foreground="#aaa"/>
                        <TextBox Text="{Binding BackgroundColor}" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="背景透明度" Width="100" Foreground="#aaa"/>
                        <Slider Minimum="0.1" Maximum="1" Value="{Binding BackgroundOpacity}" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="字体大小" Width="100" Foreground="#aaa"/>
                        <TextBox Text="{Binding FontSize}" Width="200"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <!-- 性能设置 -->
            <StackPanel Spacing="8">
                <TextBlock Text="性能" FontSize="14" FontWeight="Bold" Foreground="#a29bfe"/>
                
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="刷新间隔(ms)" Width="100" Foreground="#aaa"/>
                        <TextBox Text="{Binding RefreshInterval}" Width="200"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="游戏模式" Width="100" Foreground="#aaa"/>
                        <CheckBox IsChecked="{Binding GameMode}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="游戏模式间隔" Width="100" Foreground="#aaa"/>
                        <TextBox Text="{Binding GameModeRefreshInterval}" Width="200"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <!-- 显示设置 -->
            <StackPanel Spacing="8">
                <TextBlock Text="显示项" FontSize="14" FontWeight="Bold" Foreground="#fd79a8"/>
                
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowCpu}" Margin="0 0 8 0"/>
                        <TextBlock Text="CPU" Foreground="#aaa"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowGpu}" Margin="0 0 8 0"/>
                        <TextBlock Text="GPU" Foreground="#aaa"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowMemory}" Margin="0 0 8 0"/>
                        <TextBlock Text="内存" Foreground="#aaa"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowNetwork}" Margin="0 0 8 0"/>
                        <TextBlock Text="网络" Foreground="#aaa"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowDisk}" Margin="0 0 8 0"/>
                        <TextBlock Text="磁盘" Foreground="#aaa"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding ShowBattery}" Margin="0 0 8 0"/>
                        <TextBlock Text="电池" Foreground="#aaa"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Border Height="1" Background="#333"/>

            <!-- 按钮 -->
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="重置" Command="{Binding ResetToDefaults}" Width="80" Background="#444" Foreground="White"/>
                <Button Content="保存" Command="{Binding Save}" Width="80" Background="#4ecdc4" Foreground="Black" FontWeight="Bold" Click="OnSaveClick"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
