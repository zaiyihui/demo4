<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- 项目本地 NuGet 缓存：将缓存重定向到项目根目录下的 .nuget/ 文件夹
       这样缓存与项目一起存储，项目搬迁时无需重新下载所有包 -->
  <config>
    <add key="globalPackagesFolder" value=".nuget\packages" />
    <add key="httpCachePath" value=".nuget\http-cache" />
  </config>

  <!-- NuGet 包源 -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <!-- 包源映射（可选） -->
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
